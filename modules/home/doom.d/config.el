(after! rustic
  (defun local/rustic-cargo-current-test-no-capture ()
    "Run 'cargo test' for the test near point."
    (interactive)
    (rustic-compilation-process-live)
    (-if-let (test-to-run (setq rustic-test-arguments
                                (rustic-cargo--get-test-target)))
        (local/rustic-cargo-run-test test-to-run '("--" "--nocapture"))
      (message "Could not find test at point.")))

  (defun local/rustic-cargo-rerun-no-capture ()
    "Run 'cargo test -- --nocapture with `rustic-test-arguments'."
    (interactive)
    (local/rustic-cargo-run-test rustic-test-arguments '("--" "--nocapture")))
  (defun local/rustic-cargo-run-test (test args)
    "Run TEST which can be a single test or mod name."
    (let* ((c (append (list (rustic-cargo-bin) rustic-cargo-test-exec-command test) args))
           (buf rustic-test-buffer-name)
           (proc rustic-test-process-name)
           (mode 'rustic-cargo-test-mode))
      (rustic-compilation c (list :buffer buf :process proc :mode mode))))
  (defun local/toggle-rust-backtrace ()
    "toggle RUST_BACKTRACE env var"
    (interactive)
    (if (or (string-equal rustic-compile-backtrace "1") (string-equal rustic-compile-backtrace "full"))
        (setq rustic-compile-backtrace "0")
      (setq rustic-compile-backtrace "full"))
    (message (format "RUST_BACKTRACE set: %s" rustic-compile-backtrace)))
  (defun local/rustic-cargo-run-make (args)
    "Run TEST which can be a single test or mod name."
    (let* ((c (append (list (rustic-cargo-bin) "make" "--cwd" (lsp-workspace-root) "--makefile" (doom-path (lsp-workspace-root) "Makefile.toml")) args))
           (buf rustic-test-buffer-name)
           (proc rustic-test-process-name)
           (mode 'rustic-compilation-mode))
      (rustic-compilation c (list :buffer buf :process proc :mode mode))))
  (defun local/rustic-cargo-make-docs-open ()
    "Run TEST which can be a single test or mod name."
    (interactive)
    (local/rustic-cargo-run-make '("open-docs")))
  (defun local/rustic-cargo-make-docs ()
    "Run TEST which can be a single test or mod name."
    (interactive)
    (local/rustic-cargo-run-make '("docs")))
  (defun local/rustic-cargo-make-vscode-debug ()
    "Run TEST which can be a single test or mod name."
    (interactive)
    (local/rustic-cargo-run-make '("vscode-debug"))))

