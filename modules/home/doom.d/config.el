;; which system am i on
(defconst current-system-type
  (if (string-prefix-p "TEN" (system-name))
      (intern "work")
    (intern "personal"))
  "Symbol for current system type. `work' or `personal'")
(defmacro with-system-type (&rest clauses)
  "Execute expressions based on `current-system-type`.
Each clause should be of the form `:work BODY...` or `:personal BODY...`,
in any order. BODY... can contain single or multiple expressions."
  (let ((work-body (plist-get clauses :work))
        (personal-body (plist-get clauses :personal)))
    (cond ((eq current-system-type 'work) `(progn ,@(if (listp work-body) work-body (list work-body))))
          ((eq current-system-type 'personal) `(progn ,@(if (listp personal-body) personal-body (list personal-body))))
          (t (error "invalid system type: %s" current-system-type)))))

(with-system-type
 :work ((let ((work-config-path (expand-file-name "work-config.el" doom-user-dir)))
          (when (file-exists-p work-config-path)
            (load work-config-path)))))
;; end system detection


