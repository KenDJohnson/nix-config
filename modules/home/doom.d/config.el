(defun +lookup/definition-other-window (identifier &optional arg)
  (interactive (list (doom-thing-at-point-or-region)
                     current-prefix-arg))
  (cond ((null identifier) (user-error "Nothing under point"))
        ((+lookup--jump-to :definition identifier #'pop-to-buffer arg))
        ((user-error "Couldn't find the definition of %S" (substring-no-properties identifier)))))


(defun +lookup/references-other-window (identifier &optional arg)
  (interactive (list (doom-thing-at-point-or-region)
                     current-prefix-arg))
  (cond ((null identifier) (user-error "Nothing under point"))
        ((+lookup--jump-to :references identifier #'switch-to-buffer-other-window arg))
        ((user-error "Couldn't find references of %S" (substring-no-properties identifier)))))


(when (modulep! :tools lookup)
  (map! :nv "go" #'+lookup/definition-other-window
        :nv "gO" #'+lookup/references-other-window))

(defcustom centaur-tabs--local-buffer-blacklist
  '("*epc"
    "*helm"
    "*Helm"
    "*Compile-Log*"
    "*lsp"
    "*company"
    "*Flycheck"
    "*tramp"
    " *Mini"
    "*help"
    "*straight"
    " *temp"
    "*Help"
    "*mybuf")
  "List of buffer name prefixes to hide in tabs."
  :type '(list string))

(defun centaur-tabs-hide-tab (x)
  "Do not show buffer X in tabs."
  (let ((name (format "%s" x)))
    (or
     (window-dedicated-p (selected-window))
     (cl-some (lambda (s) (string-prefix-p s name)) centaur-tabs--local-buffer-blacklist)
     (and (string-prefix-p "magit" name)
          (not (file-name-extension name))))))

(defun centaur-tabs-blacklist-prefix (prefix)
  "Add a buffer name prefix to the blacklist for tabs."
  (interactive)
  (add-to-list 'centaur-tabs--local-buffer-blacklist prefix))

